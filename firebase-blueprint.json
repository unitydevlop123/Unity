{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "The profile and stats for a UnityDev user.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Display name of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL to the user's profile picture."
        },
        "verified": {
          "type": "boolean",
          "description": "Whether the user's email is verified."
        },
        "squadCount": {
          "type": "integer",
          "description": "Number of members in the user's Squad (followers)."
        },
        "bingeList": {
          "type": "array",
          "items": {
            "$ref": "Video"
          },
          "description": "List of videos saved for later."
        },
        "recentlyWatched": {
          "type": "array",
          "items": {
            "$ref": "Video"
          },
          "description": "History of recently watched videos."
        }
      },
      "required": ["name", "email"]
    },
    "Video": {
      "title": "Video",
      "description": "A video object.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "thumbnail": { "type": "string" },
        "duration": { "type": "string" },
        "views": { "type": "string" },
        "channel": { "type": "string" }
      }
    }
  }
}
